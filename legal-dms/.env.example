# Legal DMS Environment Configuration
# Copy this file to .env and replace the values with your actual configuration

# LLM Provider Configuration
# Supported providers: openai, ollama
LLM_PROVIDER=openai

# OpenAI Configuration (if using OpenAI)
LLM_MODEL=gpt-4o
LLM_API_KEY=your-openai-api-key-here

# Ollama Configuration (if using local models via Ollama)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2
# OLLAMA_URL=http://127.0.0.1:11434

# Embedding Model for Vector Search
EMBEDDING_MODEL=BAAI/bge-m3

# OCR Languages (comma-separated list)
# Supported: en (English), hi (Hindi), mr (Marathi)
OCR_LANGUAGES=en,hi,mr

# Auto-confirmation for Pipeline Processing
# Set to true for fully automated processing (no manual review required)
# Set to false for manual review in the Review tab
AUTO_CONFIRM=false

# Optional: Adjust these paths if you want to use custom directories
# INBOX_PATH=/path/to/your/inbox
# LIBRARY_PATH=/path/to/your/library
# WORK_PATH=/path/to/your/work
# VECTOR_DB_PATH=/path/to/your/vector_db